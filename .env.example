# =============================================================================
# Plantilla raíz — copia a `.env` y personaliza (no subas `.env` a Git).
#   cp .env.example .env
# Usada por Docker Compose y por el backend (lee `../.env` desde `backend/`).
# =============================================================================

# --- General ---
ENVIRONMENT=local
PUBLIC_BASE_URL=http://localhost
PUBLIC_API_BASE_URL=http://localhost/api
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000,http://127.0.0.1
LOG_LEVEL=INFO

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET=desarrollo_solo_cambiar_por_secreto_largo_32
JWT_ALG=HS256
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=2592000
PASSWORD_PEPPER=desarrollo_solo_cambiar_pepper_largo_32ch
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
# Directorio absoluto para binarios; vacío = carpeta `uploads/` en la raíz del repo (ignorada por Git salvo `.gitkeep`).
# UPLOAD_STORAGE_DIR=
# PARSE_TIMEOUT_SECONDS=120
# OCR_MIN_CHARS_PER_PAGE=40
# PARSER_SAVE_ARTIFACTS=true
# UNSTRUCTURED_ENABLED=false
# OCR_ENABLED=true
# OCR_TESSERACT_LANG=spa
HEALTH_HTTP_TIMEOUT_SECONDS=3

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password_local
DATABASE_URL=postgresql+psycopg://rag:rag_password_local@postgres:5432/rag

# --- Redis / Celery ---
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks_v1
RAG_VECTOR_TOP_K=50
RAG_BM25_TOP_K=50
RAG_RERANK_TOP_K=10
RAG_RRF_K=60
RAG_SEARCH_MAX_TOP_K=50
RAG_HYBRID_ENABLED=true

# --- Embeddings ---
EMBEDDING_ENABLED=true
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_SIZE_MIN=1
EMBEDDING_NORMALIZE=true
EMBEDDING_TIMEOUT_SECONDS=300

# --- Ollama ---
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800
LLM_STREAMING=true
LLM_FORCE_SPANISH=true

# --- Procesamiento de documentos ---
OCR_ENABLED=true
TESSERACT_LANGS=spa
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
MAX_CHUNK_SIZE_TOKENS=800
CHUNK_MIN_MERGE_TOKENS=50

# --- Seguridad / proxy ---
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
WAF_ENABLED=true
WAF_MODE=DetectionOnly
TRAEFIK_DASHBOARD_ENABLED=false

# --- Observabilidad ---
OBSERVABILITY_ENABLED=true
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOKI_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_local_change_me

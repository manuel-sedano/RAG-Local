# Plantilla para tests / CI (ejemplo). Copia a `.env.test` si tu pipeline lo requiere.
# Valores pensados para Docker Compose (servicios en la misma red) o localhost.

ENVIRONMENT=test
LOG_LEVEL=WARNING

# En `test`, el backend puede autocompletar JWT vacío; en CI fija uno largo.
JWT_SECRET=

DATABASE_URL=postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rag_test
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_local_dev

# --- pytest (backend): integración contra Postgres real ---
# ⚠️ Borra y recrea el esquema `public` de la base indicada. Usa solo `rag_test` (u otra dedicada).
# export TEST_DATABASE_URL="postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test"
# Ver `backend/.env.test.example` y `backend/README.md`.

# En CI dentro de Docker Compose, hostnames `redis`/`qdrant` resuelven. En WSL contra servicios con puertos en el host:
# REDIS_HOST=127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HEALTH_HTTP_TIMEOUT_SECONDS=5

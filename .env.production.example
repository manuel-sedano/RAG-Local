# Plantilla PRODUCCIÓN (solo ejemplo — reemplaza TODO antes de desplegar).
# No uses estos valores en vivo; genera secretos y URLs reales.

ENVIRONMENT=production
LOG_LEVEL=INFO

PUBLIC_BASE_URL=https://REEMPLAZA_TU_DOMINIO
PUBLIC_API_BASE_URL=https://REEMPLAZA_TU_DOMINIO/api
CORS_ALLOW_ORIGINS=https://REEMPLAZA_TU_DOMINIO

# Mínimo 32 caracteres aleatorios (staging/production).
JWT_SECRET=GENERAR_SECRETO_ALEATORIO_MINIMO_32_CARACTERES_AQUI
PASSWORD_PEPPER=GENERAR_OTRO_SECRETO_ALEATORIO_LARGO_AQUI

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

DATABASE_URL=postgresql+psycopg://USUARIO:CONTRASENA@HOST_RDS_O_INTERNO:5432/NOMBRE_BD
POSTGRES_HOST=HOST_RDS_O_INTERNO
POSTGRES_PORT=5432
POSTGRES_DB=NOMBRE_BD
POSTGRES_USER=USUARIO
POSTGRES_PASSWORD=CONTRASENA

REDIS_HOST=HOST_REDIS_GESTIONADO
REDIS_PORT=6379
CELERY_BROKER_URL=redis://HOST_REDIS:6379/0
CELERY_RESULT_BACKEND=redis://HOST_REDIS:6379/1

QDRANT_HOST=HOST_QDRANT
QDRANT_PORT=6333
OLLAMA_HOST=HOST_OLLAMA_INTERNO
OLLAMA_PORT=11434

APP_RATE_LIMIT_ENABLED=true
HEALTH_HTTP_TIMEOUT_SECONDS=3

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GENERAR_CONTRASENA_FUERTE

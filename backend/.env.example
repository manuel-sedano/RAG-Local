# Plantilla `backend/.env` (ejemplo). Copia a `backend/.env`.
# Carga: `backend/.env` y luego `../.env` (la raíz sobrescribe claves duplicadas).

ENVIRONMENT=local
JWT_SECRET=desarrollo_solo_cambiar_por_secreto_largo_32
JWT_ALG=HS256
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=2592000
PASSWORD_PEPPER=desarrollo_solo_cambiar_pepper_largo_32ch
# Host `postgres` solo resuelve dentro de la red Docker. Para alembic/pytest desde
# tu máquina (WSL), Postgres debe tener `ports` en compose y usa 127.0.0.1 (ver docker-compose).
# Contraseña alineada con servicio `postgres` en docker-compose.yml.
DATABASE_URL=postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag
REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000,http://127.0.0.1
HEALTH_HTTP_TIMEOUT_SECONDS=3

# --- Uploads / Celery (opcional; ver `docs/04-env-example.md` y `app/core/config.py`) ---
# MAX_UPLOAD_MB=50
# ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
# UPLOAD_STORAGE_DIR=
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# CELERY_TASK_ALWAYS_EAGER=false

# --- Parsing de documentos (feat/doc-parsers) ---
# PARSE_TIMEOUT_SECONDS=120
# OCR_MIN_CHARS_PER_PAGE=40
# PARSER_SAVE_ARTIFACTS=true
# UNSTRUCTURED_ENABLED=false

# --- OCR Tesseract (requiere tesseract-ocr + tesseract-ocr-spa en el sistema) ---
# OCR_ENABLED=true
# OCR_MAX_PAGES=50
# OCR_TESSERACT_LANG=spa
# OCR_TESSERACT_CMD=
# OCR_CACHE_ENABLED=true
# OCR_DPI=200
# OCR_MAX_WORKERS=2

# --- Auth (opcional; valores por defecto en `app/core/config.py`) ---
# AUTH_LOGIN_MAX_ATTEMPTS_PER_IP_PER_MINUTE=30
# AUTH_LOGIN_MAX_ATTEMPTS_PER_EMAIL_PER_MINUTE=15
# AUTH_FAILED_PASSWORD_THRESHOLD=5
# AUTH_LOCKOUT_BASE_SECONDS=60
# AUTH_LOCKOUT_MAX_SECONDS=3600
# Rate limit de login: requiere Redis alcanzable (REDIS_HOST / REDIS_PORT). Si Redis no conecta, el backend arranca igual y el rate limit se omite.

# --- pytest (solo en la terminal donde ejecutes tests; no confundir con DATABASE_URL de la app) ---
# Base DEDICADA; los tests hacen DROP SCHEMA public. Ejemplo con Postgres del compose en el host:
# export TEST_DATABASE_URL="postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test"

# Chunking (ingesta; ver docs/11-rag-flow.md)
# CHUNK_SIZE_TOKENS=500
# CHUNK_OVERLAP_TOKENS=100
# MAX_CHUNK_SIZE_TOKENS=800
# CHUNK_MIN_MERGE_TOKENS=50
# Detalle: `backend/.env.test.example` y sección «Tests de integración» en `backend/README.md`.

# Tests backend (ejemplo). Copia a `backend/.env.test` si quieres cargar variables con `set -a; source ...`.
# Para pytest, lo habitual es exportar solo lo necesario en la shell (ver README).

ENVIRONMENT=test
LOG_LEVEL=WARNING
JWT_SECRET=
DATABASE_URL=postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks_v1
# QDRANT_ENABLED=true
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
# En pytest: CHAT_LLM_BACKEND=fake (automático con ENVIRONMENT=test)
# CHAT_LLM_BACKEND=fake
# LLM_MODEL=qwen2.5:7b-instruct
CORS_ALLOW_ORIGINS=http://localhost:3000
HEALTH_HTTP_TIMEOUT_SECONDS=5

# Parsing (tests unitarios no requieren cambiar estos valores)
# PARSE_TIMEOUT_SECONDS=120
# OCR_MIN_CHARS_PER_PAGE=40
# PARSER_SAVE_ARTIFACTS=true

# Embeddings: en ENVIRONMENT=test el backend por defecto es fake (sin descargar bge-m3)
# EMBEDDING_BACKEND=fake
# EMBEDDING_FAKE_DIMENSION=64

# Chunking (tests unitarios usan valores por defecto; integración de ingesta los respeta)
# CHUNK_SIZE_TOKENS=500
# CHUNK_OVERLAP_TOKENS=100
# MAX_CHUNK_SIZE_TOKENS=800
# CHUNK_MIN_MERGE_TOKENS=50

# --- TEST_DATABASE_URL (integración pytest: auth, KB, documentos, migraciones) ---
#
# ⚠️ Los tests que usan esta URL hacen DROP SCHEMA public CASCADE y recrean el esquema.
#    Usa SIEMPRE una base DEDICADA (p. ej. rag_test), nunca la base `rag` de desarrollo.
#
# Requisitos: Postgres accesible (p. ej. `docker compose up -d postgres` en la raíz del repo).
# La primera ejecución puede crear la base `rag_test` si aún no existe.
#
# Ejemplo (WSL / host, mismo usuario que docker-compose.yml):
# export TEST_DATABASE_URL="postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test"
#
# Crear la base a mano (opcional; los tests también intentan crearla):
#   psql "postgresql://rag:rag_local_dev@127.0.0.1:5432/postgres" -c 'CREATE DATABASE rag_test;'
#
# TEST_DATABASE_URL=postgresql+psycopg://rag:rag_local_dev@127.0.0.1:5432/rag_test

# Opcional: tests con Redis real (rate limit / lockout).
# Requiere Redis en el host: `docker compose up -d redis` (puerto 127.0.0.1:6379).
# TEST_REDIS_URL=redis://127.0.0.1:6379/15

# Opcional: tests con Qdrant real (upsert, búsqueda, delete por filtro).
# Requiere Qdrant en el host: `docker compose up -d qdrant` (puerto 127.0.0.1:6333).
# TEST_QDRANT_URL=http://127.0.0.1:6333

# Retrieval híbrido (tests de integración usan BM25 en memoria; vector opcional con Qdrant)
# RAG_HYBRID_ENABLED=true
# RAG_VECTOR_TOP_K=50
# RAG_BM25_TOP_K=50

# Tests backend (ejemplo). Usar con pytest/CI o `export $(cat backend/.env.test | xargs)`.

ENVIRONMENT=test
LOG_LEVEL=WARNING
JWT_SECRET=
DATABASE_URL=postgresql+psycopg://rag:rag_password_local@postgres:5432/rag_test
REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
CORS_ALLOW_ORIGINS=http://localhost:3000
HEALTH_HTTP_TIMEOUT_SECONDS=5
